{
  "name": "rapid-scribe",
  "version": "3.15.0",
  "description": "Rapid Scribe — real-time meeting capture and transcription",
  "main": "dist-electron/main.js",
  "author": "Rapid Scribe",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && concurrently -n vite,electron -c blue,green \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --config renderer/vite.config.ts",
    "dev:electron": "node scripts/dev-electron.cjs",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build --config renderer/vite.config.ts",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder --win",
    "sidecar": "python -m sidecar.sidecar"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.rapidscribe.app",
    "productName": "Rapid Scribe",
    "directories": {
      "output": "installer_output"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/Rapid Scribe Sidecar",
        "to": "sidecar",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "aj-ebels",
      "repo": "rapid-scribe"
    }
  }
}
